generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String      @id @default(uuid())
  email         String      @unique
  name          String
  passwordHash  String
  role          String      @default("USER")
  organization  Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Organization {
  id        String    @id @default(uuid())
  name      String    @unique
  owners    User[]
  projects  Project[]
  createdAt DateTime  @default(now())
}

model Project {
  id            String       @id @default(uuid())
  name          String
  description   String?
  organization  Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  queues        Queue[]
  jobs          Job[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([organizationId])
  @@unique([organizationId, name])
}

model Queue {
  id                String         @id @default(uuid())
  name              String
  project           Project        @relation(fields: [projectId], references: [id])
  projectId         String
  priority          Int            @default(0)
  concurrency       Int            @default(5)
  retryPolicy       RetryPolicy    @relation(fields: [retryPolicyId], references: [id])
  retryPolicyId     String
  paused            Boolean        @default(false)
  rateLimitPerMinute Int           @default(0)
  shardKey          String?
  statistics        QueueStatistics?
  rateWindow        QueueRateWindow?
  jobs              Job[]
  eventSubscriptions EventSubscription[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([projectId])
  @@unique([projectId, name])
}

model QueueStatistics {
  id              String   @id @default(uuid())
  queue           Queue    @relation(fields: [queueId], references: [id])
  queueId         String   @unique
  totalQueued     Int      @default(0)
  totalCompleted  Int      @default(0)
  totalFailed     Int      @default(0)
  totalRetried    Int      @default(0)
  totalDeadLetter Int      @default(0)
  updatedAt       DateTime @updatedAt
}

model QueueRateWindow {
  id          String   @id @default(uuid())
  queue       Queue    @relation(fields: [queueId], references: [id])
  queueId     String   @unique
  windowStart DateTime
  count       Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model RetryPolicy {
  id           String @id @default(uuid())
  name         String
  strategy     String
  maxAttempts  Int    @default(3)
  delaySeconds Int    @default(30)
  createdAt    DateTime @default(now())
  queues       Queue[]
}

model EventSubscription {
  id         String @id @default(uuid())
  queue      Queue  @relation(fields: [queueId], references: [id])
  queueId    String
  eventType  String
  createdAt  DateTime @default(now())

  @@unique([queueId, eventType])
}

model Event {
  id          String   @id @default(uuid())
  type        String
  payload     String
  createdAt   DateTime @default(now())
  processedAt DateTime?
}

model Job {
  id               String        @id @default(uuid())
  queue            Queue         @relation(fields: [queueId], references: [id])
  queueId          String
  project          Project       @relation(fields: [projectId], references: [id])
  projectId        String
  type             String
  payload          String
  status           String        @default("QUEUED")
  priority         Int           @default(0)
  attempt          Int           @default(0)
  maxAttempts      Int           @default(3)
  scheduledAt      DateTime?
  availableAt      DateTime      @default(now())
  claimedBy        Worker?       @relation(fields: [claimedById], references: [id])
  claimedById      String?
  claimedAt        DateTime?
  lockOwner        String?
  lockExpiresAt    DateTime?
  lastError        String?
  failureSummary   String?
  nextRetryAt      DateTime?
  lastHeartbeatAt  DateTime?
  completedAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  executions       JobExecution[]
  logs             JobLog[]
  deadLetter       DeadLetter?
  dependencies     JobDependency[] @relation("JobDependencies")
  dependents       JobDependency[] @relation("JobDependents")

  @@index([queueId, status, availableAt])
  @@index([projectId, status])
}

model JobDependency {
  id             String @id @default(uuid())
  job            Job    @relation("JobDependencies", fields: [jobId], references: [id])
  jobId          String
  dependsOnJob   Job    @relation("JobDependents", fields: [dependsOnJobId], references: [id])
  dependsOnJobId String
  createdAt      DateTime @default(now())

  @@unique([jobId, dependsOnJobId])
}

model JobExecution {
  id          String   @id @default(uuid())
  job         Job      @relation(fields: [jobId], references: [id])
  jobId       String
  worker      Worker?  @relation(fields: [workerId], references: [id])
  workerId    String?
  attempt     Int
  status      String
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  durationMs  Int?
  error       String?
  createdAt   DateTime @default(now())

  @@index([jobId])
  @@index([workerId])
}

model Worker {
  id            String        @id @default(uuid())
  name          String
  host          String
  version       String
  lastSeenAt    DateTime      @default(now())
  heartbeats    Heartbeat[]
  claimedJobs   Job[]
  executions    JobExecution[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Heartbeat {
  id         String   @id @default(uuid())
  worker     Worker   @relation(fields: [workerId], references: [id])
  workerId   String
  healthy    Boolean  @default(true)
  details    String?
  createdAt  DateTime @default(now())

  @@index([workerId, createdAt])
}

model JobLog {
  id        String   @id @default(uuid())
  job       Job      @relation(fields: [jobId], references: [id])
  jobId     String
  message   String
  level     String   @default("INFO")
  createdAt DateTime @default(now())

  @@index([jobId, createdAt])
}

model DeadLetter {
  id          String   @id @default(uuid())
  job         Job      @relation(fields: [jobId], references: [id])
  jobId       String   @unique
  reason      String
  failedAt    DateTime @default(now())
}
